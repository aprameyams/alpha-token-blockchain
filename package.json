{
  "name": "custom-token-blockchain",
  "version": "1.0.0",
  "description": "Production-ready blockchain for hosting custom tokens with smart contracts, P2P networking, and web dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "blockchain": "ts-node src/cli/blockchain.ts",
    "node": "ts-node src/node/node.ts",
    "api": "ts-node src/api/server.ts",
    "dashboard": "npm run build && node dist/dashboard/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "blockchain",
    "cryptocurrency",
    "token",
    "smart-contracts",
    "distributed-ledger"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.0.0",
    "body-parser": "^1.20.2",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "events": "^3.3.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "level": "^8.0.0",
    "table": "^6.8.1",
    "uuid": "^9.0.0",
    "websocket": "^1.0.34",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/better-sqlite3": "^7.6.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.3.1",
    "@types/table": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "eslint": "^8.44.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
